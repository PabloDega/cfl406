<div class="panelContent" id="panelAlumnos">

    <h1>👩🏻‍🏫 Lista de alumnos <div class="btn small" id="agregarAlumno"><span>➕</span>Agregar alumno</div></h1>

    <% if (alumnos && alumnos.length > 0) { %>
        <table class="tabla">
            <thead>
                <tr>
                    <th>Codigo</th>
                    <th>Año</th>
                    <th>Sede</th>
                    <th>Curso</th>
                    <th>Inicio</th>
                    <th>Duración</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            <% alumnos.forEach(alumno => { %>
                    <tr>
                        <td><%= alumno.documento %></td>
                        <td><%= alumno.anio %></td>
                        <td><%= alumno.sede %></td>
                        <td><%= alumno.curso %></td>
                        <td><%= new Date(alumno.inicio).toLocaleDateString("es-AR") %></td>
                        <td><%= alumno.duracion %></td>
                        <td>
                            <div class="acciones">
                                <div class="btn small" data-id="<%= alumno.id %>" data-accion="ver" data-tabla="alumnos">Ver</div>
                                <div class="btn small" data-id="<%= alumno.id %>" data-accion="modificar" data-tabla="alumnos">Editar</div>
                                <div class="btn small" data-id="<%= alumno.id %>" data-accion="inscribir" data-tabla="alumnos">Cursos</div>
                                <div class="btn small" data-id="<%= alumno.id %>" data-accion="eliminar" data-tabla="alumnos">Eliminar</div>
                            </div>
                        </td>
                    </tr>
            <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No hay alumnos registrados.</p>
    <% } %>
    
</div>


<!-- pasar a la vista las variables cursos y clases que se recibieron del servidor con el motor ejs -->

<script defer>
    window.cursos = <%- JSON.stringify(cursos) %>
    window.clases = <%- JSON.stringify(clases) %>
    window.sede = <%- JSON.stringify(sedes) %>
    window.titulo = <%- JSON.stringify(titulos) %>
    window.area = <%- JSON.stringify(areas) %>
    window.modalidad = <%- JSON.stringify(modalidades) %>
    window.docente_id = <%- JSON.stringify(docentes) %>
</script>
<div class="panelContent">
    <div class="flexV max-800">
        <!-- Header de la página -->
        <div class="flexH">
            <h1>Agregar Nuevo Curso</h1>
            <div class="spacer"></div>
            <a href="/panel" class="btn">
                ← Volver al Panel
            </a>
        </div>

        <!-- Formulario principal -->
        <div class="card cardAgregarCurso">
            <form id="formAgregarCurso" method="POST" action="/panel/cursos/agregar" class="flexV">
                
                <!-- Sección: Información Básica -->
                <div class="landH">
                    📋 Información Básica
                </div>
                
                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV grow">
                        <label for="curso"><strong>Nombre del Curso *</strong></label>
                        <input type="text" id="curso" name="curso" required placeholder="Ej: Desarrollo Web Full Stack">
                    </div>

                    <div class="flexV" style="min-width: 200px;">
                        <label for="codigo"><strong>Código *</strong></label>
                        <input type="number" id="codigo" name="codigo" required placeholder="101">
                    </div>
                </div>

                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV grow">
                        <label for="titulo"><strong>Título/Certificación *</strong></label>
                        <select id="titulo" name="titulo" required>
                            <option value="">Seleccionar título...</option>
                            <% titulos.forEach(titulo => { %>
                                <option value="<%= titulo.id %>"><%= titulo.titulo %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="flexV grow">
                        <label for="area"><strong>Área *</strong></label>
                        <select id="area" name="area" required>
                            <option value="">Seleccionar área...</option>
                            <% areas.forEach(area => { %>
                                <option value="<%= area.id %>"><%= area.area %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV grow">
                        <label for="modalidad"><strong>Modalidad *</strong></label>
                        <select id="modalidad" name="modalidad" required>
                            <option value="">Seleccionar modalidad...</option>
                            <% modalidades.forEach(modalidad => { %>
                                <option value="<%= modalidad.id %>"><%= modalidad.modalidad %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="flexV grow">
                        <label for="sede"><strong>Sede *</strong></label>
                        <select id="sede" name="sede" required>
                            <option value="">Seleccionar sede...</option>
                            <% sedes.forEach(sede => { %>
                                <option value="<%= sede.id %>"><%= sede.nombre %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <!-- Sección: Fechas y Horarios -->
                <div class="landH">
                    📅 Fechas y Horarios
                </div>

                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV">
                        <label for="anio"><strong>Año *</strong></label>
                        <input type="number" id="anio" name="anio" value="2025" required style="min-width: 120px;">
                    </div>

                    <div class="flexV grow">
                        <label for="inicio"><strong>Fecha de Inicio *</strong></label>
                        <input type="date" id="inicio" name="inicio" required>
                    </div>

                    <div class="flexV grow">
                        <label for="fin"><strong>Fecha de Fin *</strong></label>
                        <input type="date" id="fin" name="fin" required>
                    </div>
                </div>

                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV grow">
                        <label for="cierre_inscripcion"><strong>Cierre de Inscripciones *</strong></label>
                        <input type="date" id="cierre_inscripcion" name="cierre_inscripcion" required>
                    </div>

                    <div class="flexV grow">
                        <label for="duracion"><strong>Duración *</strong></label>
                        <input type="text" id="duracion" name="duracion" required placeholder="Ej: 3 meses, 120 horas">
                    </div>
                </div>

                <div class="flexH" style="flex-wrap: wrap; gap: 2em;">
                    <div class="flexV grow">
                        <label for="horario"><strong>Horario *</strong></label>
                        <input type="text" id="horario" name="horario" required placeholder="Ej: 18:00 - 20:00">
                    </div>

                    <div class="flexV grow">
                        <label><strong>Días de la semana *</strong></label>
                        <div class="flexH" style="flex-wrap: wrap; gap: 1em; align-items: center;">
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="lunes" name="dias">
                                Lunes
                            </label>
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="martes" name="dias">
                                Martes
                            </label>
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="miércoles" name="dias">
                                Miércoles
                            </label>
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="jueves" name="dias">
                                Jueves
                            </label>
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="viernes" name="dias">
                                Viernes
                            </label>
                            <label style="font-weight: normal; display: flex; align-items: center; gap: 0.5em;">
                                <input type="checkbox" value="sábado" name="dias">
                                Sábado
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Sección: Profesor -->
                <div class="landH">
                    👨‍🏫 Información del Profesor
                </div>

                <select id="docente" name="docente_id" required>
                    <option value="">Seleccionar docente...</option>
                    <% docentes.forEach(docente => { %>
                        <option value="<%= docente.id %>"><%= docente.nombre %></option>
                    <% }); %>
                </select>

                <!-- Sección: Detalles del Curso -->
                <div class="landH">
                    📝 Detalles del Curso
                </div>

                <div class="flexV">
                    <label for="descripcion"><strong>Descripción *</strong></label>
                    <textarea id="descripcion" name="descripcion" required rows="4" 
                              style="resize: vertical;"
                              placeholder="Descripción completa del curso..."></textarea>
                </div>

                <div class="flexV">
                    <label for="requisitos"><strong>Requisitos (uno por línea)</strong></label>
                    <textarea id="requisitos" name="requisitos" rows="3" 
                              style=" resize: vertical;"
                              placeholder="Nivel secundario completo&#10;Conocimientos básicos de informática&#10;..."></textarea>
                </div>

                <div class="flexH" style="align-items: center; gap: 0.5em;">
                    <input type="checkbox" id="activo" name="activo" checked>
                    <label for="activo" style="font-weight: normal;">
                        Curso activo (visible para inscripciones)
                    </label>
                </div>

                <!-- Botones de acción -->
                <div class="flexH" style="gap: 1em; justify-content: flex-end; margin-top: 2em;">
                    <a href="/panel" class="btn" style="background-color: gray;">
                        ✖ Cancelar
                    </a>
                    <button type="reset" class="btn btnNaranja">
                        ↻ Limpiar
                    </button>
                    <button type="submit" class="btn btnVerde">
                        💾 Guardar Curso
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    window.clases = <%- JSON.stringify(clases) %>;
</script>
<!-- Script específico para agregar curso -->
<script type="module" src="/script/panel/agregar-curso.js"></script>